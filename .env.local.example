# Stripe — get these from https://dashboard.stripe.com/apikeys
# Use "sk_test_..." keys for development, "sk_live_..." for production
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY_HERE

# Stripe publishable key (safe to expose to the browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_PUBLISHABLE_KEY_HERE

# Your deployed URL (used for Stripe redirect URLs)
# Leave empty locally — the API route auto-detects from the request origin
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Site lock — set to "true" to force every page/API to the downtime page
# Remove or set to anything else to restore the full site
SITE_LOCKED=true
